{
  "name": "user-behaviour",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "postinstall": "ngcc --properties es2015 browser module main --first-only --create-ivy-entry-points",
    "test": "ng test",
    "eslint": "npm run eslint:ts && npm run eslint:scss",
    "eslint:fix": "npm run eslint:ts:fix && npm run eslint:scss:fix",
    "eslint:ts": "npx eslint . --ext .ts --config .\\.eslintrc.json",
    "eslint:ts:fix": "npx eslint . --ext .ts --config .\\.eslintrc.json --fix",
    "eslint:scss": "npx stylelint \"**/*.scss\"",
    "eslint:scss:fix": "npx stylelint \"**/*.scss\" --fix",
    "prettier:check": "prettier --config ./.prettierrc.json --ignore-path ./.prettierignore -c .",
    "prettier:fix": "prettier --config ./.prettierrc.json --ignore-path ./.prettierignore --write .",
    "lint": "npm run eslint && npm run prettier:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "e2e": "ng e2e",
    "client": "cd ./src &&  node ../node_modules/@viasoft/client/src/index.v2.js",
    "build:jenkins": "ng build user-behaviour-portal --configuration production --deployUrl=https://cdn-interno.korp.com.br/v1/user-behaviour/",
    "build:jenkins-prod": "ng build user-behaviour-portal --configuration production --deployUrl=https://cdn-connect.korp.com.br/v1/user-behaviour/",
    "build:single-spa": "ng build --configuration production --deploy-url http://localhost:4200/",
    "serve:single-spa": "ng serve --disable-host-check --port 4200 --deploy-url http://localhost:4200/ --live-reload false",
    "jenkins:test": "node ./test.script.js",
    "jenkins:build-application": "node ./node_modules/@angular/cli/bin/ng build !APP_NAME!APP_BUILD_SUFFIX --configuration production --output-path=!APP_FOLDER --deploy-url=!BUILD_CDN_URL",
    "jenkins:build-package:PACKAGE_NAME": "npm run build-my-package",
    "jenkins:build-parcel:PARCEL_NAME": "npm run build-my-parcel",
    "serve:dev-env-install": "node replace-dev-env-variables.js && ng serve --configuration=dev-env",
    "serve:dev-env": "ng serve --configuration=dev-env",
    "serve:dev-env2": "ng serve --configuration=dev-env --port=4201"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~18.2.2",
    "@angular/cdk": "^18.2.2",
    "@angular/common": "~18.2.2",
    "@angular/compiler": "~18.2.2",
    "@angular/core": "~18.2.2",
    "@angular/forms": "^18.2.2",
    "@angular/material": "^18.2.2",
    "@angular/platform-browser": "~18.2.2",
    "@angular/platform-browser-dynamic": "~18.2.2",
    "@angular/router": "~18.2.2",
    "@viasoft/fontawesome-pro": "6.4.8",
    "@microsoft/signalr": "5.0.9",
    "@ngx-translate/core": "~15.0.0",
    "@sentry/angular": "^9.19.0",
    "@sentry/browser": "^6.11.0",
    "@swimlane/ngx-charts": "^22.0.0",
    "@viasoft/app-core": "9.0.0-beta.15",
    "@viasoft/client": "^7.0.0-beta.50",
    "@viasoft/client-core": "^9.0.0-beta.15",
    "@viasoft/common": "^9.0.0-beta.15",
    "@viasoft/components": "^9.0.0-beta.15",
    "@viasoft/dashboard": "8.0.2",
    "@viasoft/datepicker": "9.0.1",
    "@viasoft/http": "^9.0.0-beta.15",
    "@viasoft/navigation": "^9.0.0-beta.15",
    "@viasoft/theming": "^9.0.0-beta.15",
    "@viasoft/view-template": "^9.0.0-beta.15",
    "angular-imask": "^7.6.1",
    "angular-oauth2-oidc": "~17.0.2",
    "angular2-uuid": "^1.1.1",
    "apexcharts": "~3.53.0",
    "core-js": "^2.5.4",
    "dateformat": "^4.5.1",
    "dompurify": "^2.3.0",
    "imask": "~7.6.1",
    "jwt-decode": "^4.0.0",
    "ng-apexcharts": "~1.12.0",
    "primeicons": "~7.0.0",
    "primeng": "^17.18.9",
    "rxjs": "~7.8.1",
    "single-spa": "^6.0.3",
    "single-spa-angular": "^9.2.0",
    "tslib": "^2.3.0",
    "ua-parser-js": "1.0.2",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^18.0.0",
    "@angular-devkit/build-angular": "^18.2.2",
     "@angular/cli": "~18.2.2",
    "@angular/compiler-cli": "~18.2.2",
    "@angular/language-service": "~18.2.2",
    "@types/jasmine": "~5.1.4", 
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.11.1",
    "@types/ua-parser-js": "0.7.36",
    "@typescript-eslint/eslint-plugin": "^3.9.1",
    "@typescript-eslint/parser": "^3.9.1",
    "codelyzer": "^6.0.0",
    "eslint": "^7.7.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-import-resolver-typescript": "^2.2.1",
    "eslint-plugin-import": "^2.22.0",
   "jasmine-core": "~5.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "2.0.5",
    "protractor": "~7.0.0",
    "stylelint": "^13.6.1",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-standard": "^20.0.0",
    "stylelint-scss": "^3.18.0",
    "ts-node": "~7.0.0",
    "tslint": "~6.1.0",
    "typescript": "~5.5.4"
  }
}