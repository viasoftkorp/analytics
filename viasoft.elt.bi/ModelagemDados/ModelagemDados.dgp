        '00'#13#10'        Text = '#13#10'          '#39'Tabela fato base para o pain'#39'#23' +
        '3'#39'l de resumo de fluxo de caixa. Deve'#39' +'#13#10'          '#39' ser gerada' +
        ' separada por m'#39'#234'#39's. N'#39'#227'#39'o pode ser gerada uma '#39'#250'#39'nica ' +
        'vez '#39' +'#13#10'          '#39'e reaproveitada, precisa ser sempre'#39'#13#10'#39'g' +
        'erada do "zero" para cada '#39' +'#13#10'          '#39'per'#39'#237'#39'odo analisado' +
        '.'#39'#13#10#13#10'#39'* ValorSaldoInicial: Soma do saldo banc'#39'#225'#39'ri'#39' ' +
        '+'#13#10'          '#39'o dos bancos participantes na data de inicio da an' +
        #39'#225'#39'lise.'#39'#13#10#13#10'#39'* Va'#39' +'#13#10'          '#39'lorContasPagar: Som' +
        'a de todo o contas a pagar no m'#39'#234'#39's, inclusive '#39' +'#13#10'         ' +
        ' '#39'cheques e adiantamentos a pagar.'#39'#13#10#13#10'#39'*ValorContasPaga' +
        's: Soma toda'#39' +'#13#10'          '#39's as contas pagas no m'#39'#234'#39's, inclu' +
        'sive cheques e adianentos pagos.'#39'#13 +'#13#10'          #10#13#10'#39'*Val' +
        'orContasReceber: Soma de todas as contas a receber no m'#39'#234'#39's'#39' ' +
        '+'#13#10'          '#39', inclusive cheques e adtos.'#39'#13#10#13#10'#39'*ValorCo' +
        'ntasRecebidas: Soma de t'#39' +'#13#10'          '#39'odas as contas recebidas' +
        ' no m'#39'#234'#39's, inclusive cheques e adtos.'#39'#13#10#13#10'#39'*'#39' +'#13#10'    ' +
        '      '#39' ValorPedidoVenda: Soma de todos os pedidos de venda em a' +
        'berto, '#39' +'#13#10'          '#39'dentro do m'#39'#234'#39's.'#39'#13#10#13#10'#39'* ValorP' +
        'edidoCompra: Soma de todos os pedidos '#39' +'#13#10'          '#39'de compra ' +
        'em aberto com data de entrega no m'#39'#234'#39's.'#39'#13#10#13#10'#39'* ValorP' +
        'rovis'#39' +'#13#10'          '#39'aoDebito: Soma de todas as provis'#39'#245'#39'es a' +
        ' debito.'#39'#13#10#13#10'#39'*ValorProvisao'#39' +'#13#10'          '#39'Credito: Som' +
        'a de todas as provis'#39'#245'#39'es a cr'#39'#233'#39'dito.'#39'#13#10#13#10'#39'*Valor' +
        'Resultad'#39' +'#13#10'          '#39'o: ValorContasReceber+ValorContasRecebid' +
        'as+ValorPedidoVenda+Valo'#39' +'#13#10'          '#39'rProvisaoCredito-ValorCo' +
        'ntasPagar-ValorContasPagas-ValorPedidoCo'#39' +'#13#10'          '#39'mpra-'#39'#1' +
        '3#10'#39'ValorProvisaoDebito'#39'#13#10#13#10'#39'ValorSaldoFinal: ValorSald' +
        'oInicial'#39' +'#13#10'          '#39' - ValorResultado'#39'#13#10#13#10'#13#10'        ' +
        'Clip = False'#13#10'        WordWrap = True'#13#10'        DControlFont = Tr' +
